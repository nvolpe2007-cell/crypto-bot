# Shell scripts must keep LF line endings — a CRLF in the shebang breaks
# execution on the Linux VPS (e.g. `/usr/bin/env bash\r: No such file`).
*.sh text eol=lf

# The canonical cron line is installed verbatim into the VPS crontab — a CRLF
# would corrupt the schedule. Force LF.
deploy/swing_cron.txt text eol=lf
