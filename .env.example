# ── Kraken API credentials (required for live trading) ────────────────────────
# Generate at: https://www.kraken.com/u/security/api
# Required permissions: Query Funds, Query Open Orders & Trades,
#                       Create & Modify Orders, Cancel/Close Orders
KRAKEN_API_KEY=your_key_here
KRAKEN_API_SECRET=your_secret_here

# ── Telegram alerts (optional but recommended) ────────────────────────────────
# Create a bot via @BotFather, get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ENABLED=true

# ── Live trading overrides (optional — defaults match config.yaml) ─────────────
# Max USD loss per session before the bot stops for the day
MAX_DAILY_LOSS=15

# Set to true to allow short positions (disabled by default for first live run)
ENABLE_SHORTS=false
